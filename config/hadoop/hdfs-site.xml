<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>
    <!-- Replication factor for development (single node) -->
    <property>
        <name>dfs.replication</name>
        <value>1</value>
    </property>

    <!-- Use hostnames instead of IP addresses to resolve datanodes (essential for Docker network) -->
    <property>
        <name>dfs.client.use.datanode.hostname</name>
        <value>true</value>
    </property>
    <property>
        <name>dfs.datanode.use.datanode.hostname</name>
        <value>true</value>
    </property>
</configuration>
